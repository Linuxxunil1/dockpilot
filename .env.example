# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Passwort + Secret generieren:
#   DASH_PASSWORD:  openssl rand -base64 12
#   DASH_SECRET:    openssl rand -hex 32   (signiert das Session-Cookie)

DASH_USER=admin
DASH_PASSWORD=changeme
DASH_SECRET=bitte-mit-openssl-rand-hex-32-ersetzen
